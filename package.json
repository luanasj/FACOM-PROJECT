{
	"name": "facom-bot",
	"version": "2.0.0",
	"description": "FACOM-bot desktop control panel",
	"main": "electron/main.js",
	"scripts": {
		"start": "electron .",
		"pack": "electron-builder --dir",
		"dist": "electron-builder",
		"release": "electron-builder --publish always",
		"test": "echo \"Error: no test specified\" && exit 1"
	},
	"dependencies": {
		"electron-updater": "^6.8.3",
		"whatsapp-web.js": "^1.34.6"
	},
	"devDependencies": {
		"electron": "^33.0.0",
		"electron-builder": "^26.8.1"
	},
	"build": {
		"appId": "br.com.leiaute.facom-bot",
		"productName": "FACOM-bot",
		"directories": {
			"output": "dist"
		},
		"toolsets": {
			"winCodeSign": "1.1.0"
		},
		"files": [
			"electron/**/*",
			"wwebjs/**/*",
			"package.json",
			"!**/logs.txt",
			"!**/.wwebjs_auth/**",
			"!**/.wwebjs_cache/**"
		],
		"extraResources": [
			{
				"from": "assets",
				"to": "assets"
			}
		],
		"asarUnpack": [
			"node_modules/whatsapp-web.js/**",
			"node_modules/puppeteer*/**"
		],
		"win": {
			"target": "nsis",
			"signAndEditExecutable": false
		},
		"nsis": {
			"oneClick": false,
			"perMachine": false,
			"allowToChangeInstallationDirectory": true
		},
		"publish": [
			{
				"provider": "github",
				"owner": "luanasj",
				"repo": "facom-bot"
			}
		]
	},
	"author": "",
	"license": "ISC"
}
